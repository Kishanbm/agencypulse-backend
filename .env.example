# ═══════════════════════════════════════════════════════════════════════════════
# AgencyPulse — Backend Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ═══════════════════════════════════════════════════════════════════════════════

# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
# APP_URL: used in invitation email links (must be accessible by the recipient)
APP_URL=http://localhost:5173
# FRONTEND_URL: where OAuth callbacks redirect after success/failure
FRONTEND_URL=http://localhost:5173

# ─── Database ─────────────────────────────────────────────────────────────────
POSTGRES_USER=agencypulse
POSTGRES_PASSWORD=agencypulse_dev
POSTGRES_DB=agencypulse
DATABASE_URL="postgresql://agencypulse:agencypulse_dev@localhost:5432/agencypulse?schema=public"
# MIGRATION_DATABASE_URL: superuser role for running migrations (bypasses RLS).
# Defaults to DATABASE_URL if not set. In production use a separate DB owner role.
MIGRATION_DATABASE_URL="postgresql://postgres:postgres@localhost:5432/agencypulse?schema=public"

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_dev

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate secrets with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# OAuth state JWTs also use JWT_ACCESS_SECRET (10-minute TTL, CSRF protection).
JWT_ACCESS_SECRET=change_me_generate_a_long_random_hex_string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_me_generate_a_different_long_random_hex_string
JWT_REFRESH_EXPIRES_IN=7d

# ─── Encryption ───────────────────────────────────────────────────────────────
# AES-256-GCM key for encrypting OAuth tokens at rest.
# Must be exactly 64 hex characters (32 bytes). App refuses to start if wrong.
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=change_me_must_be_exactly_64_hex_chars_00000000000000000000000000000000

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
# Works with any SMTP provider: Resend, SendGrid, Mailgun, Gmail, etc.
# For local dev: Mailhog is included in docker-compose (port 1025 / UI port 8025).
EMAIL_FROM=noreply@agencypulse.com
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=

# ─── File Storage (S3-compatible) ─────────────────────────────────────────────
# Local dev: MinIO is included in docker-compose (http://localhost:9000, UI port 9001).
# Production: use Cloudflare R2 or AWS S3.
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_ACCESS_KEY=agencypulse
STORAGE_SECRET_KEY=agencypulse_dev
STORAGE_BUCKET=agencypulse
STORAGE_REGION=auto

# ─── Sync Scheduler ───────────────────────────────────────────────────────────
# Cron expression (UTC) for the background data sync scheduler.
# Default: every 6 hours. Examples: hourly = '0 * * * *', daily 2AM = '0 2 * * *'
SYNC_CRON=0 */6 * * *

# ═══════════════════════════════════════════════════════════════════════════════
# INTEGRATION PLATFORMS
# Each platform requires its own developer app / API credentials.
# All redirect URIs must be registered in the respective developer console.
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Google (shared OAuth app — covers GA4, Google Ads, Search Console, YouTube)
# Create at: https://console.cloud.google.com → APIs & Services → Credentials
# Create an OAuth 2.0 Client ID (Web application type).
# Enable APIs: Analytics Data API, Google Ads API, Search Console API, YouTube Analytics API.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Each integration has its own redirect URI — all must be registered in Google Cloud Console.
GOOGLE_REDIRECT_URI=http://localhost:3000/api/v1/integrations/ga4/callback
GOOGLE_ADS_REDIRECT_URI=http://localhost:3000/api/v1/integrations/google-ads/callback
GOOGLE_SEARCH_CONSOLE_REDIRECT_URI=http://localhost:3000/api/v1/integrations/google-search-console/callback
YOUTUBE_REDIRECT_URI=http://localhost:3000/api/v1/integrations/youtube/callback
# Google Ads developer token — from https://ads.google.com/aw/apicenter
# Test account token works for dev; apply for Basic access for production.
GOOGLE_ADS_DEVELOPER_TOKEN=
# Optional: MCC (manager account) customer ID — digits only, no dashes.
# Set this if your agency uses a Google Ads manager account.
GOOGLE_ADS_MANAGER_CUSTOMER_ID=

# ─── Meta Ads (Facebook / Instagram Ads) ──────────────────────────────────────
# Create at: https://developers.facebook.com → My Apps → Create App (type: Business)
# Add product: Marketing API. Request permissions: ads_read, ads_management.
META_APP_ID=
META_APP_SECRET=
META_ADS_REDIRECT_URI=http://localhost:3000/api/v1/integrations/meta-ads/callback

# ─── LinkedIn Ads ──────────────────────────────────────────────────────────────
# Create at: https://www.linkedin.com/developers/apps
# Required permissions: r_ads, r_ads_reporting
# These scopes require LinkedIn Marketing Developer Platform access (apply separately).
# Enable "Refresh Token" in app settings to receive 365-day refresh tokens.
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_ADS_REDIRECT_URI=http://localhost:3000/api/v1/integrations/linkedin-ads/callback

# ─── TikTok Ads ────────────────────────────────────────────────────────────────
# Create at: https://business-api.tiktok.com → My Apps → Create App
# IMPORTANT: TikTok callback returns "auth_code" (not "code") — handled automatically.
# Access tokens expire in 24 hours. No refresh tokens — users re-connect when expired.
TIKTOK_APP_ID=
TIKTOK_APP_SECRET=
TIKTOK_ADS_REDIRECT_URI=http://localhost:3000/api/v1/integrations/tiktok-ads/callback

# ─── Amazon Ads ────────────────────────────────────────────────────────────────
# Create at: https://advertising.amazon.com/API/docs/en-us/onboarding/overview
# Uses Login with Amazon (LWA) OAuth. Required scope: advertising::campaign_management
# Register the redirect URI in your LWA security profile.
# Reports are generated asynchronously (polled within sync job, max 90 seconds).
AMAZON_ADS_CLIENT_ID=
AMAZON_ADS_CLIENT_SECRET=
AMAZON_ADS_REDIRECT_URI=http://localhost:3000/api/v1/integrations/amazon-ads/callback

# ═══════════════════════════════════════════════════════════════════════════════
# AI & BILLING (Phase 8)
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Anthropic (Claude AI) ────────────────────────────────────────────────────
# Used for: AI report summaries (Phase 8.4) and AI assistant chat (Phase 8.5).
# Get key at: https://console.anthropic.com
# Optional in development — AI features warn on startup if key is absent.
ANTHROPIC_API_KEY=
# Override default models (optional — defaults shown below)
# ANTHROPIC_CHAT_MODEL=claude-haiku-4-5-20251001
# ANTHROPIC_REPORT_MODEL=claude-haiku-4-5-20251001

# ─── Stripe (Billing & Subscriptions) ─────────────────────────────────────────
# Create at: https://dashboard.stripe.com → Developers → API keys
# Use test keys (sk_test_...) for development, live keys (sk_live_...) for production.
#
# Setup steps:
#   1. Create two Products in Stripe: "Agency" and "Agency Pro" (recurring, monthly)
#   2. Copy the Price IDs (price_...) from each product into the vars below
#   3. Set up a webhook endpoint in Stripe → Developers → Webhooks:
#      URL: https://yourdomain.com/api/v1/billing/webhook
#      Events: customer.subscription.created, customer.subscription.updated,
#              customer.subscription.deleted, invoice.payment_succeeded,
#              invoice.payment_failed, checkout.session.completed
#   4. Copy the webhook signing secret (whsec_...) below
#
# For local webhook testing: use Stripe CLI → stripe listen --forward-to localhost:3000/api/v1/billing/webhook
STRIPE_SECRET_KEY=sk_test_
STRIPE_WEBHOOK_SECRET=whsec_
STRIPE_PRICE_ID_AGENCY=price_
STRIPE_PRICE_ID_AGENCY_PRO=price_
