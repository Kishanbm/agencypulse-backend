# ═══════════════════════════════════════════════════════════════════════════════
# AgencyPulse — Backend Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ═══════════════════════════════════════════════════════════════════════════════

# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
# APP_URL: used in invitation email links (must be accessible by the recipient)
APP_URL=http://localhost:5173
# FRONTEND_URL: where OAuth callbacks redirect after success/failure
FRONTEND_URL=http://localhost:5173

# ─── Database ─────────────────────────────────────────────────────────────────
POSTGRES_USER=agencypulse
POSTGRES_PASSWORD=agencypulse_dev
POSTGRES_DB=agencypulse
DATABASE_URL="postgresql://agencypulse:agencypulse_dev@localhost:5432/agencypulse?schema=public"
# MIGRATION_DATABASE_URL: superuser role for running migrations (bypasses RLS).
# Defaults to DATABASE_URL if not set. In production use a separate DB owner role.
MIGRATION_DATABASE_URL="postgresql://postgres:postgres@localhost:5432/agencypulse?schema=public"

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_dev

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate secrets with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# OAuth state JWTs also use JWT_ACCESS_SECRET (10-minute TTL, CSRF protection).
JWT_ACCESS_SECRET=change_me_generate_a_long_random_hex_string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_me_generate_a_different_long_random_hex_string
JWT_REFRESH_EXPIRES_IN=7d

# ─── Encryption ───────────────────────────────────────────────────────────────
# AES-256-GCM key for encrypting OAuth tokens at rest.
# Must be exactly 64 hex characters (32 bytes). App refuses to start if wrong.
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=change_me_must_be_exactly_64_hex_chars_00000000000000000000000000000000

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
# Works with any SMTP provider: Resend, SendGrid, Mailgun, Gmail, etc.
# For local dev: Mailhog is included in docker-compose (port 1025 / UI port 8025).
EMAIL_FROM=noreply@agencypulse.com
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=

# ─── File Storage (S3-compatible) ─────────────────────────────────────────────
# Local dev: MinIO is included in docker-compose (http://localhost:9000, UI port 9001).
# Production: use Cloudflare R2 or AWS S3.
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_ACCESS_KEY=agencypulse
STORAGE_SECRET_KEY=agencypulse_dev
STORAGE_BUCKET=agencypulse
STORAGE_REGION=auto

# ─── Sync Scheduler ───────────────────────────────────────────────────────────
# Cron expression (UTC) for the background data sync scheduler.
# Default: every 6 hours. Examples: hourly = '0 * * * *', daily 2AM = '0 2 * * *'
SYNC_CRON=0 */6 * * *

# ═══════════════════════════════════════════════════════════════════════════════
# INTEGRATION PLATFORMS
# Each platform requires its own developer app / API credentials.
# All redirect URIs must be registered in the respective developer console.
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Google (shared OAuth app — covers GA4, Google Ads, Search Console, YouTube)
# Create at: https://console.cloud.google.com → APIs & Services → Credentials
# Create an OAuth 2.0 Client ID (Web application type).
# Enable APIs: Analytics Data API, Google Ads API, Search Console API, YouTube Analytics API.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Each integration has its own redirect URI — all must be registered in Google Cloud Console.
GOOGLE_REDIRECT_URI=http://localhost:3000/api/v1/integrations/ga4/callback
GOOGLE_ADS_REDIRECT_URI=http://localhost:3000/api/v1/integrations/google-ads/callback
GOOGLE_SEARCH_CONSOLE_REDIRECT_URI=http://localhost:3000/api/v1/integrations/google-search-console/callback
YOUTUBE_REDIRECT_URI=http://localhost:3000/api/v1/integrations/youtube/callback
# Google Ads developer token — from https://ads.google.com/aw/apicenter
# Test account token works for dev; apply for Basic access for production.
GOOGLE_ADS_DEVELOPER_TOKEN=
# Optional: MCC (manager account) customer ID — digits only, no dashes.
# Set this if your agency uses a Google Ads manager account.
GOOGLE_ADS_MANAGER_CUSTOMER_ID=

# ─── Meta Ads (Facebook / Instagram Ads) ──────────────────────────────────────
# Create at: https://developers.facebook.com → My Apps → Create App (type: Business)
# Add product: Marketing API. Request permissions: ads_read, ads_management.
META_APP_ID=
META_APP_SECRET=
META_ADS_REDIRECT_URI=http://localhost:3000/api/v1/integrations/meta-ads/callback

# ─── LinkedIn Ads ──────────────────────────────────────────────────────────────
# Create at: https://www.linkedin.com/developers/apps
# Required permissions: r_ads, r_ads_reporting
# These scopes require LinkedIn Marketing Developer Platform access (apply separately).
# Enable "Refresh Token" in app settings to receive 365-day refresh tokens.
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_ADS_REDIRECT_URI=http://localhost:3000/api/v1/integrations/linkedin-ads/callback

# ─── TikTok Ads ────────────────────────────────────────────────────────────────
# Create at: https://business-api.tiktok.com → My Apps → Create App
# IMPORTANT: TikTok callback returns "auth_code" (not "code") — handled automatically.
# Access tokens expire in 24 hours. No refresh tokens — users re-connect when expired.
TIKTOK_APP_ID=
TIKTOK_APP_SECRET=
TIKTOK_ADS_REDIRECT_URI=http://localhost:3000/api/v1/integrations/tiktok-ads/callback

# ─── Amazon Ads ────────────────────────────────────────────────────────────────
# Create at: https://advertising.amazon.com/API/docs/en-us/onboarding/overview
# Uses Login with Amazon (LWA) OAuth. Required scope: advertising::campaign_management
# Register the redirect URI in your LWA security profile.
# Reports are generated asynchronously (polled within sync job, max 90 seconds).
AMAZON_ADS_CLIENT_ID=
AMAZON_ADS_CLIENT_SECRET=
AMAZON_ADS_REDIRECT_URI=http://localhost:3000/api/v1/integrations/amazon-ads/callback

# ═══════════════════════════════════════════════════════════════════════════════
# AI & BILLING (Phase 8)
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Anthropic (Claude AI) ────────────────────────────────────────────────────
# Used for: AI report summaries (Phase 8.4) and AI assistant chat (Phase 8.5).
# Get key at: https://console.anthropic.com
# Optional in development — AI features warn on startup if key is absent.
ANTHROPIC_API_KEY=
# Override default models (optional — defaults shown below)
# ANTHROPIC_CHAT_MODEL=claude-haiku-4-5-20251001
# ANTHROPIC_REPORT_MODEL=claude-haiku-4-5-20251001

# ─── Stripe (Billing & Subscriptions) ─────────────────────────────────────────
# Create at: https://dashboard.stripe.com → Developers → API keys
# Use test keys (sk_test_...) for development, live keys (sk_live_...) for production.
#
# Setup steps:
#   1. Create two Products in Stripe: "Agency" and "Agency Pro" (recurring, monthly)
#   2. Copy the Price IDs (price_...) from each product into the vars below
#   3. Set up a webhook endpoint in Stripe → Developers → Webhooks:
#      URL: https://yourdomain.com/api/v1/billing/webhook
#      Events: customer.subscription.created, customer.subscription.updated,
#              customer.subscription.deleted, invoice.payment_succeeded,
#              invoice.payment_failed, checkout.session.completed
#   4. Copy the webhook signing secret (whsec_...) below
#
# For local webhook testing: use Stripe CLI → stripe listen --forward-to localhost:3000/api/v1/billing/webhook
STRIPE_SECRET_KEY=sk_test_
STRIPE_WEBHOOK_SECRET=whsec_
STRIPE_PRICE_ID_AGENCY=price_
STRIPE_PRICE_ID_AGENCY_PRO=price_

# ═══════════════════════════════════════════════════════════════════════════════
# PHASE 3.8+ — NEW INTEGRATION PLATFORMS
# Add credentials as you obtain developer app access for each platform.
# All redirect URIs must be registered in the respective developer console.
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Microsoft Ads ────────────────────────────────────────────────────────────
# Create at: https://ads.microsoft.com → Tools → API Access → Create App
# OAuth 2.0 (Authorization Code flow). Required scope: msads.manage
MICROSOFT_ADS_CLIENT_ID=
MICROSOFT_ADS_CLIENT_SECRET=
MICROSOFT_ADS_REDIRECT_URI=http://localhost:3000/api/v1/integrations/microsoft-ads/callback

# ─── Pinterest Ads ────────────────────────────────────────────────────────────
# Create at: https://developers.pinterest.com → My Apps → Create App
# Required scopes: ads:read
PINTEREST_APP_ID=
PINTEREST_APP_SECRET=
PINTEREST_REDIRECT_URI=http://localhost:3000/api/v1/integrations/pinterest-ads/callback

# ─── Snapchat Ads ─────────────────────────────────────────────────────────────
# Create at: https://businesshelp.snapchat.com/s/article/business-api
# Required scope: snapchat-marketing-api
SNAPCHAT_CLIENT_ID=
SNAPCHAT_CLIENT_SECRET=
SNAPCHAT_REDIRECT_URI=http://localhost:3000/api/v1/integrations/snapchat-ads/callback

# ─── X Ads (Twitter Ads) ──────────────────────────────────────────────────────
# Create at: https://developer.twitter.com → Projects & Apps → Create App
# Uses OAuth 1.0a for Ads API. Required access level: Ads API (apply separately).
X_ADS_API_KEY=
X_ADS_API_SECRET_KEY=
X_ADS_ACCESS_TOKEN=
X_ADS_ACCESS_TOKEN_SECRET=
X_ADS_REDIRECT_URI=http://localhost:3000/api/v1/integrations/x-ads/callback

# ─── Reddit Ads ───────────────────────────────────────────────────────────────
# Create at: https://www.reddit.com/prefs/apps → Create App
# Required scope: ads:read
REDDIT_ADS_CLIENT_ID=
REDDIT_ADS_CLIENT_SECRET=
REDDIT_ADS_REDIRECT_URI=http://localhost:3000/api/v1/integrations/reddit-ads/callback

# ─── Shopify ──────────────────────────────────────────────────────────────────
# Create at: https://partners.shopify.com → Apps → Create App
# OAuth 2.0. Required scopes: read_analytics, read_orders, read_products
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_REDIRECT_URI=http://localhost:3000/api/v1/integrations/shopify/callback

# ─── Mailchimp ────────────────────────────────────────────────────────────────
# Create at: https://mailchimp.com/developer/ → Register App
# OAuth 2.0.
MAILCHIMP_CLIENT_ID=
MAILCHIMP_CLIENT_SECRET=
MAILCHIMP_REDIRECT_URI=http://localhost:3000/api/v1/integrations/mailchimp/callback

# ─── Klaviyo ──────────────────────────────────────────────────────────────────
# Create at: https://www.klaviyo.com/account#api-keys-tab
# API Key (private key with read permissions)
KLAVIYO_API_KEY=

# ─── HubSpot ──────────────────────────────────────────────────────────────────
# Create at: https://developers.hubspot.com → Apps → Create App
# OAuth 2.0. Required scopes: crm.objects.contacts.read, analytics.access
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=
HUBSPOT_REDIRECT_URI=http://localhost:3000/api/v1/integrations/hubspot/callback

# ─── Semrush ──────────────────────────────────────────────────────────────────
# Get key at: https://www.semrush.com/api/ → API Keys
SEMRUSH_API_KEY=

# ─── CallRail ─────────────────────────────────────────────────────────────────
# Create at: https://app.callrail.com/oauth/applications → Create Application
# Or use API key from Account → Integrations → API Keys
CALLRAIL_API_KEY=

# ─── Google Business Profile ──────────────────────────────────────────────────
# Uses shared Google OAuth app. Requires additional API: My Business API
# Enable at: https://console.cloud.google.com → APIs → My Business Business Information API
GOOGLE_BUSINESS_PROFILE_REDIRECT_URI=http://localhost:3000/api/v1/integrations/google-business-profile/callback

# ─── ActiveCampaign ───────────────────────────────────────────────────────────
# Get API credentials from: ActiveCampaign Account → Settings → Developer
ACTIVECAMPAIGN_API_URL=
ACTIVECAMPAIGN_API_KEY=

# ─── Brevo (Sendinblue) ───────────────────────────────────────────────────────
# Get API key from: https://app.brevo.com/settings/keys/api
BREVO_API_KEY=

# ─── Constant Contact ─────────────────────────────────────────────────────────
# Create at: https://app.constantcontact.com/pages/acc/developer-app-review
CONSTANT_CONTACT_CLIENT_ID=
CONSTANT_CONTACT_CLIENT_SECRET=
CONSTANT_CONTACT_REDIRECT_URI=http://localhost:3000/api/v1/integrations/constant-contact/callback

# ─── Campaign Monitor ─────────────────────────────────────────────────────────
# Get API key from: https://yourapp.createsend.com/api/api-keys
CAMPAIGN_MONITOR_API_KEY=

# ─── ConvertKit ───────────────────────────────────────────────────────────────
# Get API key from: https://app.convertkit.com/account_settings/advanced
CONVERTKIT_API_KEY=

# ─── Drip ─────────────────────────────────────────────────────────────────────
# Get API key from: https://www.drip.com/app/account → Integrations → API
DRIP_API_KEY=

# ─── WooCommerce ──────────────────────────────────────────────────────────────
# Generate per-store: WooCommerce → Settings → Advanced → REST API → Add Key
WOOCOMMERCE_CONSUMER_KEY=
WOOCOMMERCE_CONSUMER_SECRET=

# ─── BigCommerce ──────────────────────────────────────────────────────────────
# Create at: https://devtools.bigcommerce.com → Create App
BIGCOMMERCE_CLIENT_ID=
BIGCOMMERCE_CLIENT_SECRET=
BIGCOMMERCE_REDIRECT_URI=http://localhost:3000/api/v1/integrations/bigcommerce/callback

# ─── Stripe (Ecommerce data, separate from billing Stripe) ───────────────────
# Uses Restricted Key with read access to Charges, Customers, Subscriptions
STRIPE_ECOMMERCE_API_KEY=

# ─── Keap (Infusionsoft) ──────────────────────────────────────────────────────
# Create at: https://keys.developer.keap.com/my-apps → Create App
KEAP_CLIENT_ID=
KEAP_CLIENT_SECRET=
KEAP_REDIRECT_URI=http://localhost:3000/api/v1/integrations/keap/callback

# ─── Salesforce ───────────────────────────────────────────────────────────────
# Create at: https://developer.salesforce.com → Connected Apps
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
SALESFORCE_REDIRECT_URI=http://localhost:3000/api/v1/integrations/salesforce/callback

# ─── Matomo ───────────────────────────────────────────────────────────────────
# Self-hosted: your Matomo URL + API token from Personal Settings → Security
MATOMO_API_URL=
MATOMO_API_TOKEN=

# ─── Ahrefs ───────────────────────────────────────────────────────────────────
# Get API key at: https://ahrefs.com/api/
AHREFS_API_KEY=

# ─── Moz ──────────────────────────────────────────────────────────────────────
# Create at: https://moz.com/api → Credentials
MOZ_ACCESS_ID=
MOZ_SECRET_KEY=

# ─── CallTrackingMetrics ──────────────────────────────────────────────────────
# Get credentials from: https://app.calltrackingmetrics.com/settings/access_keys
CTM_ACCESS_KEY=
CTM_SECRET_KEY=

# ─── BrightLocal ──────────────────────────────────────────────────────────────
# Get API key from: https://tools.brightlocal.com/seo-tools/api
BRIGHTLOCAL_API_KEY=

# ─── Yext ─────────────────────────────────────────────────────────────────────
# Create at: https://hitchhikers.yext.com/guides/hitchhikers-platform
YEXT_CLIENT_ID=
YEXT_CLIENT_SECRET=
YEXT_REDIRECT_URI=http://localhost:3000/api/v1/integrations/yext/callback

# ─── Google BigQuery ──────────────────────────────────────────────────────────
# Uses shared Google OAuth app. Requires BigQuery API enabled in Google Cloud Console.
GOOGLE_BIGQUERY_REDIRECT_URI=http://localhost:3000/api/v1/integrations/google-bigquery/callback

# ─── Google Ad Manager ────────────────────────────────────────────────────────
# Uses shared Google OAuth app. Requires DFP / Ad Manager API enabled in Google Cloud Console.
GOOGLE_AD_MANAGER_REDIRECT_URI=http://localhost:3000/api/v1/integrations/google-ad-manager/callback

# ─── Google Display & Video 360 ───────────────────────────────────────────────
# Uses shared Google OAuth app. Requires Display Video API enabled.
GOOGLE_DV360_REDIRECT_URI=http://localhost:3000/api/v1/integrations/google-dv360/callback

# ─── Google Local Services Ads ────────────────────────────────────────────────
# Uses shared Google OAuth app. Requires Local Services API enabled.
GOOGLE_LOCAL_SERVICES_ADS_REDIRECT_URI=http://localhost:3000/api/v1/integrations/google-local-services-ads/callback

# ─── Bing Webmaster Tools ─────────────────────────────────────────────────────
# Uses shared Microsoft OAuth app (same MICROSOFT_ADS_CLIENT_ID / SECRET).
# Register a separate redirect URI in Azure AD for Bing Webmaster Tools.
BING_WEBMASTER_TOOLS_REDIRECT_URI=http://localhost:3000/api/v1/integrations/bing-webmaster-tools/callback

# ─── AdRoll ───────────────────────────────────────────────────────────────────
# Create an app at https://developers.adroll.com/
ADROLL_CLIENT_ID=
ADROLL_CLIENT_SECRET=
ADROLL_REDIRECT_URI=http://localhost:3000/api/v1/integrations/adroll/callback

# ─── Spotify Ads Studio ───────────────────────────────────────────────────────
# Create an app at https://developer.spotify.com/dashboard
SPOTIFY_ADS_CLIENT_ID=
SPOTIFY_ADS_CLIENT_SECRET=
SPOTIFY_ADS_REDIRECT_URI=http://localhost:3000/api/v1/integrations/spotify-ads/callback

# ─── Vimeo ────────────────────────────────────────────────────────────────────
# Create an app at https://developer.vimeo.com/apps
VIMEO_CLIENT_ID=
VIMEO_CLIENT_SECRET=
VIMEO_REDIRECT_URI=http://localhost:3000/api/v1/integrations/vimeo/callback

# ─── Snowflake ────────────────────────────────────────────────────────────────
# Set up a dedicated service account in Snowflake with SELECT grants
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USERNAME=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_WAREHOUSE=
SNOWFLAKE_DATABASE=
